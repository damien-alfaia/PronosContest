# =====================================================================
#  PronosticsContest v2 — variables d'environnement
#  Copie ce fichier en `.env.local` (ignoré par git) et remplis-le.
# =====================================================================

# --- Supabase (front, exposées au navigateur) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase (server-only, JAMAIS dans le front) ---
# À utiliser uniquement dans les Edge Functions / scripts serveur.
SUPABASE_SERVICE_ROLE_KEY=

# --- API externes ---
API_FOOTBALL_KEY=
RESEND_API_KEY=
